# Anamnesis Backend — Environment variables
# Copy to .env and fill in values. Never commit .env.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
# development | staging | production. Production loads secrets from AWS Secrets Manager.

SECRET_KEY=
# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

VAPID_PRIVATE_KEY=
# Web Push VAPID private key (for PWA notifications).

VAPID_EMAIL=mailto:admin@example.com
# Web Push contact email (required by spec).

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://anamnesis:anamnesis_dev@localhost:5432/anamnesis
# Async PostgreSQL URL. Use postgresql+asyncpg (not psycopg2).

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Broker for Celery and cache/rate-limiting.

# -----------------------------------------------------------------------------
# AWS (required for production; optional for local)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=anamnesis-uploads
AWS_SECRETS_MANAGER_PREFIX=anamnesis/
# In production, secrets (SECRET_KEY, API keys, etc.) are loaded from here.

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# -----------------------------------------------------------------------------
# Microsoft OAuth (Azure AD / Microsoft Identity Platform)
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback

# -----------------------------------------------------------------------------
# Slack OAuth
# -----------------------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/auth/slack/callback
SLACK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Notion OAuth
# -----------------------------------------------------------------------------
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/auth/notion/callback

# -----------------------------------------------------------------------------
# AI APIs
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Encryption (token encryption at rest)
# -----------------------------------------------------------------------------
ENCRYPTION_MASTER_KEY=
# 32-byte key for Fernet (AES-256). Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# -----------------------------------------------------------------------------
# Frontend (OAuth redirect whitelist, CORS)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional: Sentry
# -----------------------------------------------------------------------------
SENTRY_DSN=
