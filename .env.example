# Anamnesis Backend — Environment variables
# Copy to .env and fill in values. Never commit .env.
# Every variable in app/config.py is listed below, grouped by category.

# =============================================================================
# APP
# =============================================================================
APP_ENV=development
# development | staging | production. Production loads secrets from AWS Secrets Manager.

SECRET_KEY=
# JWT signing key for access/refresh tokens. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

VAPID_PRIVATE_KEY=
# Web Push VAPID private key (PWA push notifications). Generate at https://vapidkeys.com/

VAPID_EMAIL=mailto:admin@example.com
# Web Push contact email (required by spec).

FRONTEND_URL=http://localhost:3000
# CORS allowed origin and OAuth redirect base. Set to your frontend URL in production.

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql+asyncpg://anamnesis:anamnesis_dev@localhost:5432/anamnesis
# Async PostgreSQL URL. Must use postgresql+asyncpg (asyncpg driver). pgvector extension required.

DATABASE_POOL_SIZE=20
# Connection pool size (1–100).

DATABASE_MAX_OVERFLOW=10
# Max overflow connections (0–50).

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# Redis URL for Celery broker, result backend, rate limiting, refresh tokens, cache.

# =============================================================================
# AWS
# =============================================================================
AWS_REGION=us-east-1
# AWS region for S3 and Secrets Manager.

AWS_ACCESS_KEY_ID=
# IAM access key for S3 uploads and (optional) Secrets Manager. Leave blank if using instance role.

AWS_SECRET_ACCESS_KEY=
# IAM secret key. Leave blank if using instance role.

S3_BUCKET_NAME=anamnesis-uploads
# S3 bucket for user uploads (voice notes, exports). Create in AWS Console.

AWS_SECRETS_MANAGER_PREFIX=anamnesis/
# Prefix for secret names in AWS Secrets Manager. In production, app loads {prefix}/app.

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
GOOGLE_CLIENT_ID=
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID.

GOOGLE_CLIENT_SECRET=
# Client secret from the same OAuth client.

GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Authorized redirect URI. Must match frontend or backend callback URL in Google Console.

# =============================================================================
# MICROSOFT OAUTH
# =============================================================================
MICROSOFT_CLIENT_ID=
# Azure AD app (application) ID from Azure Portal → App registrations.

MICROSOFT_CLIENT_SECRET=
# Client secret from the same app.

MICROSOFT_TENANT_ID=common
# common | organizations | or your tenant ID for single-tenant.

MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
# Redirect URI registered in Azure app.

# =============================================================================
# SLACK OAUTH
# =============================================================================
SLACK_CLIENT_ID=
# From Slack API → Your App → OAuth & Permissions.

SLACK_CLIENT_SECRET=
# Client secret from the same app.

SLACK_REDIRECT_URI=http://localhost:3000/auth/slack/callback
# Redirect URI added under OAuth in Slack app.

SLACK_SIGNING_SECRET=
# Signing secret for Slack webhooks (Request URL verification). From Basic Information.

# =============================================================================
# NOTION OAUTH
# =============================================================================
NOTION_CLIENT_ID=
# From Notion integration settings.

NOTION_CLIENT_SECRET=
# Client secret from the same integration.

NOTION_REDIRECT_URI=http://localhost:3000/auth/notion/callback
# Redirect URI for OAuth.

# =============================================================================
# AI APIS
# =============================================================================
ANTHROPIC_API_KEY=
# From Anthropic Console. Used for Claude (queries, analysis, briefings).

OPENAI_API_KEY=
# From OpenAI. Used for embeddings (optional fallback).

# =============================================================================
# WEB PUSH
# =============================================================================
# VAPID keys are under APP (VAPID_PRIVATE_KEY, VAPID_EMAIL). No separate section needed.

# =============================================================================
# ENCRYPTION
# =============================================================================
ENCRYPTION_MASTER_KEY=
# 32-byte Fernet key for encrypting OAuth tokens at rest. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# =============================================================================
# CELERY
# =============================================================================
# Celery uses REDIS_URL as broker and backend. No separate Celery env vars.

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=
# Sentry DSN for error tracking. Optional. From Sentry project → Client Keys.

# =============================================================================
# STRIPE (future — leave blank)
# =============================================================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Used for subscriptions and account deletion Stripe cancellation. Post-launch.
